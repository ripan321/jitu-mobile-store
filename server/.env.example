# ── SERVER ──
PORT=5000
NODE_ENV=development

# ── MONGODB ──
# Get this from: https://cloud.mongodb.com → Create cluster → Connect → Drivers
MONGODB_URI=MONGODB_URI=mongodb+srv://jitu:RipanDas70028@cluster0.ysariox.mongodb.net/jitu-mobile?retryWrites=true&w=majority&appName=Cluster0

# ── JWT ──
# Make this a long random string (e.g. open terminal: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# ── ADMIN CREDENTIALS (first run creates this admin) ──
ADMIN_EMAIL=admin@jitumobile.com
ADMIN_PASSWORD=JituAdmin@2024
ADMIN_NAME=Jitu Mobile Admin

# ── EMAIL (Gmail SMTP) ──
# Step 1: Go to Google Account → Security → 2-Step Verification → ON
# Step 2: Google Account → Security → App Passwords → Generate for "Mail"
# Step 3: Paste the 16-character app password below (no spaces)
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=xxxx_xxxx_xxxx_xxxx
EMAIL_FROM="Jitu Mobile Store <your_gmail@gmail.com>"
ADMIN_NOTIFY_EMAIL=admin@jitumobile.com

# ── CLOUDINARY (Image Upload) ──
# Get from: https://console.cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── FRONTEND URL (for CORS) ──
CLIENT_URL=http://localhost:3000
